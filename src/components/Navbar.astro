---
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const isHome = currentPath === "";
const hashPrefix = isHome ? "" : "/";
const bookHref = isHome ? "#contact" : "/#contact";

const links = [
  { href: `${hashPrefix}#top`, label: "Home" },
  { href: `${hashPrefix}#about`, label: "About" },
  { href: `${hashPrefix}#capabilities`, label: "Capabilities" },
  { href: `${hashPrefix}#services`, label: "What we do" },
  { href: `${hashPrefix}#security`, label: "Engineering" },
  { href: `${hashPrefix}#process`, label: "Process" },
  { href: `${hashPrefix}#resources`, label: "Resources" },
  { href: `${hashPrefix}#contact`, label: "Start" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <div class="nav-shell">
      <nav class="nav nav-pill" id="primary-nav" aria-label="Primary">
        <span class="nav-indicator" aria-hidden="true"></span>
        {links.map((link, index) => (
          <a href={link.href} class={"nav-link" + (index === 0 ? " is-active" : "")}>
            {link.label}
          </a>
        ))}
      </nav>
      <div class="header-actions nav-actions">
        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="primary-nav"
        >
          Menu
        </button>
        <a class="btn btn-ghost" href={bookHref}>Book a Call</a>
        <a class="btn btn-primary" href="/sales">Get Started</a>
      </div>
    </div>
  </div>
</header>
