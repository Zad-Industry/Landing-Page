---
import Section from "./Section.astro";
import ChartContainer from "./ChartContainer.astro";
---

<Section id="security" className="security">
  <div class="container">
    <div class="section-header" data-reveal>
      <p class="eyebrow">Engineering standards</p>
      <h2>Quality practices are built into every delivery.</h2>
    </div>
    <div class="security-feed" data-reveal style="--delay: 80ms">
      <div>
        <p class="panel-label">Delivery checks</p>
        <h3>Engineering signals tracked per release</h3>
      </div>
      <div class="security-tags">
        <span>Test coverage</span>
        <span>Refactor scope</span>
        <span>Release stability</span>
        <span>Secure coding checks</span>
      </div>
    </div>
    <div class="security-dashboard" data-reveal style="--delay: 120ms">
      <div class="security-metric">
        <div>
          <span class="panel-label">Code quality</span>
          <strong data-metric="coverage">86%</strong>
        </div>
        <p class="metric-note">Critical flows covered by automated tests.</p>
      </div>
      <ChartContainer className="security-graph" data-chart="quality" style="--chart-ratio: 16 / 9">
        <div class="chart-orbit" data-orbit="quality">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="chart-legend">
          <span>Quality trend</span>
          <span class="chart-value" data-metric="quality">+18%</span>
        </div>
        <svg class="sparkline" viewBox="0 0 160 48" role="img" aria-label="Quality trend">
          <path
            data-sparkline
            d="M4 38 C 20 30, 38 28, 56 22 C 74 18, 92 16, 110 12 C 128 10, 146 14, 156 8"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
          />
        </svg>
        <div class="chart-bars" data-bars aria-hidden="true">
          <span style="--bar: 0.32"></span>
          <span style="--bar: 0.48"></span>
          <span style="--bar: 0.54"></span>
          <span style="--bar: 0.64"></span>
          <span style="--bar: 0.72"></span>
          <span style="--bar: 0.82"></span>
          <span style="--bar: 0.88"></span>
          <span style="--bar: 0.93"></span>
        </div>
        <p class="chart-caption">Quality improves as refactors reduce complexity.</p>
      </ChartContainer>
      <div class="security-metric">
        <div>
          <span class="panel-label">Vulnerability reduction</span>
          <strong data-metric="mttr">3.2%</strong>
        </div>
        <p class="metric-note">High-risk findings addressed during delivery.</p>
      </div>
    </div>
    <div class="security-grid">
      <article class="card security-card" data-reveal style="--delay: 60ms">
        <h3>White-Box Testing</h3>
        <p>We analyze internal system logic and code structure to ensure:</p>
        <ul class="bullet-list">
          <li>High code coverage</li>
          <li>Early bug detection</li>
          <li>Stable and predictable system behavior</li>
        </ul>
        <div class="security-tags">
          <span>Coverage gates</span>
          <span>Static analysis</span>
          <span>Regression suite</span>
        </div>
      </article>
      <article class="card security-card" data-reveal style="--delay: 120ms">
        <h3>Secure-by-default delivery</h3>
        <p>Security is part of the engineering lifecycle, not a separate track:</p>
        <ul class="bullet-list">
          <li>Secure coding standards</li>
          <li>Automated checks in CI/CD</li>
          <li>Dependency and config reviews</li>
          <li>Release validation steps</li>
        </ul>
        <div class="security-tags">
          <span>Pipeline checks</span>
          <span>Review gates</span>
          <span>Release docs</span>
        </div>
      </article>
    </div>
    <p class="security-note" data-reveal style="--delay: 180ms">
      Engineering standards are part of every build, not a separate service.
    </p>
  </div>
</Section>
