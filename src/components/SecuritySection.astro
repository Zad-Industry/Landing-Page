<section class="section security" id="security" data-reveal="section">
  <div class="container">
    <div class="section-header" data-reveal>
      <p class="eyebrow">Built-in security &amp; quality</p>
      <h2>Security and testing are not add-ons -- they are built into everything we deliver.</h2>
    </div>
    <div class="security-feed" data-reveal style="--delay: 80ms">
      <div>
        <p class="panel-label">Live security feed</p>
        <h3>Blocked risks in the last 7 days</h3>
      </div>
      <div class="security-tags">
        <span>Auth abuse 214</span>
        <span>Misconfig 98</span>
        <span>API rate spikes 67</span>
        <span>Dependency alerts 41</span>
      </div>
    </div>
    <div class="security-dashboard" data-reveal style="--delay: 120ms">
      <div class="security-metric">
        <div>
          <span class="panel-label">Active coverage</span>
          <strong data-metric="coverage">86%</strong>
        </div>
        <p class="metric-note">Critical services monitored with automated scans.</p>
      </div>
      <div class="security-graph" data-chart="threats">
        <div class="chart-orbit" data-orbit="threats">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="chart-legend">
          <span>Threats mitigated</span>
          <span class="chart-value" data-metric="threats">+18%</span>
        </div>
        <svg class="sparkline" viewBox="0 0 160 48" role="img" aria-label="Threat mitigation trend">
          <path
            data-sparkline
            d="M4 38 C 20 30, 38 28, 56 22 C 74 18, 92 16, 110 12 C 128 10, 146 14, 156 8"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
          />
        </svg>
        <div class="chart-bars" data-bars aria-hidden="true">
          <span style="--bar: 0.32"></span>
          <span style="--bar: 0.48"></span>
          <span style="--bar: 0.54"></span>
          <span style="--bar: 0.64"></span>
          <span style="--bar: 0.72"></span>
          <span style="--bar: 0.82"></span>
          <span style="--bar: 0.88"></span>
          <span style="--bar: 0.93"></span>
        </div>
        <p class="chart-caption">Abuse blocks increase as traffic scales.</p>
      </div>
      <div class="security-metric">
        <div>
          <span class="panel-label">Time to fix</span>
          <strong data-metric="mttr">36 hrs</strong>
        </div>
        <p class="metric-note">Median time to remediate critical findings.</p>
      </div>
    </div>
    <div class="security-grid">
      <article class="card security-card" data-reveal style="--delay: 60ms">
        <h3>White-Box Testing</h3>
        <p>We analyze internal system logic and code structure to ensure:</p>
        <ul class="bullet-list">
          <li>High code coverage</li>
          <li>Early bug detection</li>
          <li>Stable and predictable system behavior</li>
        </ul>
      </article>
      <article class="card security-card" data-reveal style="--delay: 120ms">
        <h3>DevSecOps Integration</h3>
        <p>Security is embedded into our development lifecycle:</p>
        <ul class="bullet-list">
          <li>Secure coding practices</li>
          <li>Continuous security checks</li>
          <li>Dependency vulnerability scanning</li>
          <li>CI/CD pipeline protection</li>
        </ul>
      </article>
    </div>
    <p class="security-note" data-reveal style="--delay: 180ms">
      Every system is delivered secure, tested, and production-ready.
    </p>
  </div>
</section>
