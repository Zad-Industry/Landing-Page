<section class="section contact" id="contact-form" data-reveal="section">
  <div class="container">
    <div class="section-header" data-reveal>
      <p class="eyebrow">Start a project</p>
      <h2>Tell us about your system. We respond within 24 hours.</h2>
      <p class="section-body">Share timelines, risks, or deadlines and we will send a clear plan.</p>
    </div>
    <div class="contact-grid">
      <form class="contact-form" data-reveal style="--delay: 120ms">
        <label>
          Full name
          <input type="text" name="name" placeholder="Your name" required />
        </label>
        <label>
          Work email
          <input type="email" name="email" placeholder="name@company.com" required />
        </label>
        <label>
          Company size
          <select name="company" required>
            <option value="">Select range</option>
            <option value="1-10">1-10</option>
            <option value="11-50">11-50</option>
            <option value="51-200">51-200</option>
            <option value="201+">201+</option>
          </select>
        </label>
        <label>
          What do you need help with?
          <textarea name="message" rows="4" placeholder="Tell us about your system"></textarea>
        </label>
        <button class="btn btn-primary" type="submit">Submit request</button>
        <p class="form-note" role="status" aria-live="polite">
          Prefer email? Reach us at hello@zadindustry.com.
        </p>
      </form>
      <div class="contact-panel" data-reveal style="--delay: 180ms">
        <h3>What happens next</h3>
        <ul class="bullet-list">
          <li>We review your request within 24 hours.</li>
          <li>We schedule a discovery call within 2-3 business days.</li>
          <li>We provide a scope, timeline, and delivery plan.</li>
        </ul>
        <div class="contact-box">
          <p>Security assessments available on request.</p>
          <span>Enterprise-ready engagements.</span>
        </div>
      </div>
    </div>
  </div>
</section>
