<section class="section" id="process" data-reveal="section">
  <div class="container">
    <div class="section-header" data-reveal>
      <p class="eyebrow">Our process</p>
      <h2>Clear steps to move from idea to secure delivery.</h2>
    </div>
    <div class="process-grid">
      <div class="card process-step" data-reveal style="--delay: 40ms">
        <span class="step-number">01</span>
        <h3>Discovery</h3>
        <p>We analyze your product goals, constraints, and current system risks.</p>
        <span class="step-meta">2-3 days</span>
      </div>
      <div class="card process-step" data-reveal style="--delay: 80ms">
        <span class="step-number">02</span>
        <h3>Plan</h3>
        <p>We deliver a scope, delivery roadmap, and architecture decisions.</p>
        <span class="step-meta">5-7 days</span>
      </div>
      <div class="card process-step" data-reveal style="--delay: 120ms">
        <span class="step-number">03</span>
        <h3>Ship</h3>
        <p>We build secure, tested releases with weekly demos and milestones.</p>
        <span class="step-meta">2-week cadence</span>
      </div>
      <div class="card process-step" data-reveal style="--delay: 160ms">
        <span class="step-number">04</span>
        <h3>Operate</h3>
        <p>We monitor, harden, and optimize for real traffic and growth.</p>
        <span class="step-meta">Ongoing</span>
      </div>
    </div>
  </div>
</section>
