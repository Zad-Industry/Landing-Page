---
import Section from "./Section.astro";
---

<Section className="hero">
  <div class="container hero-grid">
    <div class="hero-content" data-reveal>
      <p class="eyebrow">Engineering partner</p>
      <p class="hero-brand">Zad Industry</p>
      <h1>System development and engineering for teams that need to ship fast and stay stable.</h1>
      <p class="lead">
        We design, build, extend, and refactor software systems for startups and growing teams,
        with secure engineering practices built into every delivery.
      </p>
      <ul class="hero-list">
        <li>System development and architecture upgrades</li>
        <li>Feature delivery and platform extensions</li>
        <li>Refactoring and performance optimization</li>
      </ul>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#contact">Get Started</a>
      </div>
      <div class="hero-trust" data-reveal style="--delay: 120ms">
        <div class="trust-card">
          <span class="trust-value">Systems</span>
          <span class="trust-label">Backend + platform work</span>
        </div>
        <div class="trust-card">
          <span class="trust-value">Features</span>
          <span class="trust-label">Delivery + extension</span>
        </div>
        <div class="trust-card">
          <span class="trust-value">Portals</span>
          <span class="trust-label">Dashboards + internal tools</span>
        </div>
      </div>
      <div class="engagement" data-reveal style="--delay: 180ms">
        <div>
          <p class="engagement-title">Engagement models</p>
          <p class="engagement-copy">Sprint delivery, system rescue, or ongoing engineering.</p>
        </div>
        <a class="btn btn-ghost" href="#contact">Book a Call</a>
      </div>
    </div>
    <div class="hero-visual" data-reveal style="--delay: 200ms">
      <div class="visual-card">
        <div class="visual-header">
          <span class="chip">Delivery Board</span>
          <span class="status">In progress</span>
        </div>
        <div class="visual-body">
          <div class="metric">
            <span>Architecture</span>
            <strong>Restructured</strong>
          </div>
          <div class="metric">
            <span>Refactor plan</span>
            <strong>In motion</strong>
          </div>
          <div class="metric">
            <span>Delivery scope</span>
            <strong>Features + systems</strong>
          </div>
        </div>
        <div class="scan-lines" aria-hidden="true"></div>
      </div>
      <div class="orbital-wrap" aria-hidden="true">
        <div class="orbital"></div>
        <div class="shield">
          <svg viewBox="0 0 200 200" role="img" aria-label="Shield icon">
            <path
              d="M100 20 L160 40 L160 95 C160 135 135 165 100 180 C65 165 40 135 40 95 L40 40 Z"
              fill="none"
              stroke="currentColor"
              stroke-width="6"
            />
            <path
              d="M75 95 L95 115 L130 80"
              fill="none"
              stroke="currentColor"
              stroke-width="8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
      </div>
    </div>
  </div>
</Section>
