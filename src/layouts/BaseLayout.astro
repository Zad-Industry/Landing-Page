---
import "../styles/global.css";

const {
  title = "zad | Scalable, Secure Systems",
  description = "zad builds scalable, secure software systems for startups and growing businesses.",
} = Astro.props;
const ogImage = Astro.site ? new URL("/og-image.svg", Astro.site).toString() : "/og-image.svg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="zad" />
    <meta name="apple-mobile-web-app-title" content="zad" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#070b11" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="zad" />
    <link rel="canonical" href="https://zadindustry.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://zadindustry.com/" />
    <meta property="og:site_name" content="zad" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="zad security-first engineering" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.ico?v=3" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#070b11" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&family=Sora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "zad",
        "url": "https://zadindustry.com/",
        "description": "zad builds scalable, secure software systems for startups and growing businesses.",
        "foundingDate": "2026",
        "areaServed": "Worldwide",
        "slogan": "Building scalable, secure systems from day one"
      }
    </script>
  </head>
  <body id="top">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-one" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-two" aria-hidden="true"></div>

    <header class="site-header">
      <div class="container header-inner">
        <div class="nav-shell">
          <nav class="nav nav-pill" id="primary-nav" aria-label="Primary">
            <span class="nav-indicator" aria-hidden="true"></span>
            <a href="#top" class="nav-link is-active">Home</a>
            <a href="#about" class="nav-link">About</a>
            <a href="#capabilities" class="nav-link">Capabilities</a>
            <a href="#services" class="nav-link">What we do</a>
            <a href="#security" class="nav-link">Security</a>
            <a href="#process" class="nav-link">Process</a>
            <a href="#contact" class="nav-link">Start</a>
          </nav>
          <div class="header-actions nav-actions">
            <button
              class="menu-toggle"
              type="button"
              aria-expanded="false"
              aria-controls="primary-nav"
            >
              Menu
            </button>
            <a class="btn btn-ghost" href="#contact">Book a Call</a>
            <a class="btn btn-primary" href="#contact">Get Started</a>
          </div>
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-top">
        <div class="footer-brand">
          <div>
            <span class="footer-logo">Zad Industry</span>
            <p>
              Security-first engineering for startups and scaleups that need reliable delivery and
              production-ready systems.
            </p>
          </div>
          <form class="footer-form" aria-label="Subscribe" data-default-subject="Subscribe request from landing page">
            <label>
              Stay in the loop
              <div class="footer-input">
                <input type="email" name="email" placeholder="name@company.com" required />
                <button class="btn btn-primary" type="submit">Subscribe</button>
              </div>
            </label>
            <span
              class="footer-note footer-note-form"
              role="status"
              aria-live="polite"
              data-default="No spam. Security, delivery, and readiness updates."
            >
              No spam. Security, delivery, and readiness updates.
            </span>
          </form>
        </div>
        <div class="footer-links">
          <div>
            <span class="footer-title">Solutions</span>
            <a href="#services">Services</a>
            <a href="#capabilities">Capabilities</a>
            <a href="#security">Security</a>
            <a href="#process">Process</a>
          </div>
          <div>
            <span class="footer-title">Company</span>
            <a href="#about">About</a>
            <a href="#clients">Clients</a>
            <a href="#faq">FAQs</a>
            <a href="#contact-form">Contact</a>
          </div>
          <div>
            <span class="footer-title">Resources</span>
            <a
              href="mailto:m9nx11@gmail.com?subject=Delivery%20Readiness%20Worksheet%20Request&body=Hi%20Zad%20Team,%0A%0APlease%20send%20the%20delivery%20readiness%20worksheet.%0A%0AName:%0ACompany:%0ALaunch%20timeline:%0A"
              >Delivery readiness worksheet</a
            >
            <a href="#readiness">Release gate checklist</a>
            <a href="#security">Security review guide</a>
            <a href="#impact">Launch impact metrics</a>
          </div>
          <div>
            <span class="footer-title">Contact</span>
            <a href="mailto:m9nx11@gmail.com">m9nx11@gmail.com</a>
            <a href="tel:+10000000000">+1 (000) 000-0000</a>
            <span class="footer-note">Worldwide delivery</span>
          </div>
        </div>
      </div>
      <div class="container footer-bottom">
        <div class="footer-cta">
          <div>
            <span class="footer-title">Delivery readiness kit</span>
            <p>
              Review SLOs, QA gates, and risk ownership before launch. We will send the worksheet
              within 48 hours.
            </p>
          </div>
          <div class="footer-actions">
            <a class="btn btn-primary" href="#contact-form">Start a project</a>
            <a
              class="btn btn-ghost"
              href="mailto:m9nx11@gmail.com?subject=Delivery%20Readiness%20Worksheet%20Request&body=Hi%20Zad%20Team,%0A%0APlease%20send%20the%20delivery%20readiness%20worksheet.%0A%0AName:%0ACompany:%0ALaunch%20timeline:%0A"
              >Get the readiness worksheet</a
            >
          </div>
        </div>
        <div class="footer-meta">
          <span>© 2026 Zad Industry. All rights reserved.</span>
          <div class="footer-social">
            <a href="https://linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a>
            <a href="https://github.com" target="_blank" rel="noreferrer">GitHub</a>
            <a href="https://x.com" target="_blank" rel="noreferrer">X</a>
          </div>
        </div>
      </div>
    </footer>

    <script src="/scripts/main.js" defer></script>
  </body>
</html>
