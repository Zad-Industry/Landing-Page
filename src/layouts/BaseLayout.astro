---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

const {
  title = "Zad Industry | System Development & Engineering",
  description =
    "Zad Industry builds and improves software systems, features, and internal platforms for startups and growing businesses, with secure engineering built in.",
} = Astro.props;
const ogImage = Astro.site ? new URL("/og-image.svg", Astro.site).toString() : "/og-image.svg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="Zad Industry" />
    <meta name="apple-mobile-web-app-title" content="Zad Industry" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#070b11" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Zad Industry" />
    <link rel="canonical" href="https://zadindustry.tech/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://zadindustry.tech/" />
    <meta property="og:site_name" content="Zad Industry" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Zad Industry engineering systems" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.ico?v=3" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#070b11" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&family=Sora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Zad Industry",
        "url": "https://zadindustry.tech/",
        "description": "Zad Industry builds and improves software systems, features, and internal platforms for startups and growing businesses, with secure engineering built in.",
        "foundingDate": "2026",
        "areaServed": "Worldwide",
        "slogan": "Building systems with secure-by-default engineering"
      }
    </script>
  </head>
  <body id="top">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-one" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-two" aria-hidden="true"></div>

    <Navbar />

    <slot />

    <footer class="site-footer">
      <div class="container footer-top">
        <div class="footer-brand">
          <div>
            <span class="footer-logo">Zad Industry</span>
            <p>
              Engineering partner for system development, feature delivery, refactoring, and
              internal platforms with secure coding built in.
            </p>
          </div>
          <form class="footer-form" aria-label="Subscribe" data-default-subject="Subscribe request from landing page">
            <label>
              Stay in the loop
              <div class="footer-input">
                <input type="email" name="email" placeholder="name@company.com" required />
                <button class="btn btn-primary" type="submit">Subscribe</button>
              </div>
            </label>
            <span
              class="footer-note footer-note-form"
              role="status"
              aria-live="polite"
                data-default="No spam. Engineering, delivery, and system updates."
            >
              No spam. Engineering, delivery, and system updates.
            </span>
          </form>
        </div>
        <div class="footer-links">
          <div>
            <span class="footer-title">Solutions</span>
          <a href="#services">Services</a>
            <a href="#capabilities">Capabilities</a>
            <a href="#security">Engineering standards</a>
            <a href="#process">Process</a>
          </div>
          <div>
            <span class="footer-title">Company</span>
          <a href="#about">About</a>
            <a href="#clients">Clients</a>
            <a href="#faq">FAQs</a>
            <a href="#contact-form">Contact</a>
          </div>
          <div>
            <span class="footer-title">Resources</span>
            <a
              href="mailto:info@zadindustry.tech?subject=Delivery%20Readiness%20Guide%20Request&body=Hi%20Zad%20Industry%20team,%0A%0APlease%20send%20the%20delivery%20readiness%20guide.%0A%0AName:%0ACompany:%0ALaunch%20timeline:%0A"
              >Delivery readiness guide</a
            >
            <a href="#readiness">Release gate checklist</a>
            <a href="#security">Engineering review guide</a>
            <a href="#impact">Launch impact metrics</a>
          </div>
          <div>
            <span class="footer-title">Contact</span>
            <a href="mailto:info@zadindustry.tech">info@zadindustry.tech</a>
            <span class="footer-note">Worldwide delivery</span>
          </div>
        </div>
      </div>
      <div class="container footer-bottom">
        <div class="footer-cta">
          <div>
          <span class="footer-title">Delivery readiness kit</span>
          <p>
            Review QA gates, system scope, and release owners before launch. We will send the guide
            within 48 hours.
          </p>
          </div>
          <div class="footer-actions">
            <a class="btn btn-primary" href="#contact-form">Start a project</a>
            <a
              class="btn btn-ghost"
              href="mailto:info@zadindustry.tech?subject=Delivery%20Readiness%20Guide%20Request&body=Hi%20Zad%20Industry%20team,%0A%0APlease%20send%20the%20delivery%20readiness%20guide.%0A%0AName:%0ACompany:%0ALaunch%20timeline:%0A"
              >Get the readiness guide</a
            >
          </div>
        </div>
        <div class="footer-meta">
          <span>© 2026 Zad Industry. All rights reserved.</span>
          <div class="footer-social">
            <a href="https://www.linkedin.com/company/zad-industry" target="_blank" rel="noreferrer">LinkedIn</a>
            <a href="https://github.com/Zad-Industry" target="_blank" rel="noreferrer">GitHub</a>
            <a href="https://x.com/ZadIndustry" target="_blank" rel="noreferrer">X</a>
          </div>
        </div>
      </div>
    </footer>

    <script src="/scripts/main.js" defer></script>
  </body>
</html>
