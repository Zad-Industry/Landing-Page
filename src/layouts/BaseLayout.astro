---
import "../styles/global.css";

const {
  title = "Zad Industry | Scalable, Secure Systems",
  description =
    "Zad Industry builds scalable, secure software systems for startups and growing businesses.",
} = Astro.props;
const ogImage = Astro.site ? new URL("/og-image.svg", Astro.site).toString() : "/og-image.svg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070b11" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Zad Industry" />
    <link rel="canonical" href="https://zadindustry.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://zadindustry.com/" />
    <meta property="og:site_name" content="Zad Industry" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Zad Industry security-first engineering" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="icon"
      href="/assets/Orange and Black Modern Business Logo.svg"
      type="image/svg+xml"
    />
    <link rel="shortcut icon" href="/assets/Orange and Black Modern Business Logo.svg" />
    <link
      rel="icon"
      href="/assets/Orange and Black Modern Business Logo (1).png"
      type="image/png"
    />
    <link rel="apple-touch-icon" href="/assets/Orange and Black Modern Business Logo (1).png" />
    <!-- Inline data-URI favicon (base64 SVG) for broader tab support -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml;base64,"
    />
    <!-- Fallbacks and tile color for some platforms -->
    <meta name="msapplication-TileColor" content="#070b11" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&family=Sora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Zad Industry",
        "url": "https://zadindustry.com/",
        "description": "Zad Industry builds scalable, secure software systems for startups and growing businesses.",
        "foundingDate": "2026",
        "areaServed": "Worldwide",
        "slogan": "Building scalable, secure systems from day one"
      }
    </script>
  </head>
  <body id="top">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-one" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-two" aria-hidden="true"></div>

    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="#top" aria-label="Zad Industry home">
          <img
            src="/assets/Orange and Black Modern Business Logo (1).png"
            alt="Zad Industry logo"
            class="brand-logo"
          />
          <span class="brand-text">Zad Industry</span>
        </a>
        <nav class="nav" id="primary-nav" aria-label="Primary">
          <a href="#about">About</a>
          <a href="#capabilities">Capabilities</a>
          <a href="#services">What we do</a>
          <a href="#security">Security</a>
          <a href="#process">Process</a>
          <a href="#contact">Start</a>
        </nav>
        <div class="header-actions">
          <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
            Menu
          </button>
          <a class="btn btn-ghost" href="#contact">Book a Call</a>
          <a class="btn btn-primary" href="#contact">Get Started</a>
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-inner">
        <span>Zad Industry &copy; 2026</span>
        <span>Engineering scalable systems for modern businesses.</span>
        <span>hello@zadindustry.com</span>
      </div>
    </footer>

    <script src="/scripts/main.js" defer></script>
  </body>
</html>
